#%RAML 1.0 DataType

type: object
description: Prospective customer contact details supplied by REALS.
properties:
  firstName?:
    type: string
    description: Customer first name.
  lastName:
    type: string
    description: Customer last name. Mandatory - maps to the Salesforce standard Lead LastName field.
  email?:
    type: string
    description: Customer email address.
  phone?:
    type: string
    description: Customer phone number.
  company?:
    type: string
    description: Company name. Maps to the Salesforce standard Lead Company field (defaults to "REALS Prospect" when absent).
